+/* Benchmark: tight loop of Py_BEGIN/END_CRITICAL_SECTION.
+ * Placed before the #undef so the macros resolve to the inlined path.
+ * This is compiled into libpython with full PGO + LTO. */
+__attribute__((visibility("default"), used))
+double
+_PyCriticalSection_BenchCS1(PyObject *op, int iterations)
+{
+#ifdef Py_GIL_DISABLED
+    struct timespec start, end;
+    clock_gettime(CLOCK_MONOTONIC, &start);
+    for (int i = 0; i < iterations; i++) {
+        Py_BEGIN_CRITICAL_SECTION(op);
+        Py_END_CRITICAL_SECTION();
+    }
+    clock_gettime(CLOCK_MONOTONIC, &end);
+    return (double)(end.tv_sec - start.tv_sec)
+         + (double)(end.tv_nsec - start.tv_nsec) / 1e9;
+#else
+    return 0.0;
+#endif
+}
+
+__attribute__((visibility("default"), used))
+double
+_PyCriticalSection_BenchCS2(PyObject *op1, PyObject *op2, int iterations)
+{
+#ifdef Py_GIL_DISABLED
+    struct timespec start, end;
+    clock_gettime(CLOCK_MONOTONIC, &start);
+    for (int i = 0; i < iterations; i++) {
+        Py_BEGIN_CRITICAL_SECTION2(op1, op2);
+        Py_END_CRITICAL_SECTION2();
+    }
+    clock_gettime(CLOCK_MONOTONIC, &end);
+    return (double)(end.tv_sec - start.tv_sec)
+         + (double)(end.tv_nsec - start.tv_nsec) / 1e9;
+#else
+    return 0.0;
+#endif
+}
+
 #undef PyCriticalSection_Begin
 void
 PyCriticalSection_Begin(PyCriticalSection *c, PyObject *op)
