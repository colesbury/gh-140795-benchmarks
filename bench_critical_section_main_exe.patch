+/* Thin wrappers around benchmark functions in Python/critical_section.c
+ * which is part of libpython (compiled with PGO + LTO). */
+extern double _PyCriticalSection_BenchCS1(PyObject *op, int iterations);
+extern double _PyCriticalSection_BenchCS2(PyObject *op1, PyObject *op2, int iterations);
+
+static PyObject *
+_testinternalcapi_bench_critical_section(PyObject *self, PyObject *args)
+{
+    PyObject *obj;
+    int iterations;
+    if (!PyArg_ParseTuple(args, "Oi", &obj, &iterations))
+        return NULL;
+    double elapsed = _PyCriticalSection_BenchCS1(obj, iterations);
+    return PyFloat_FromDouble(elapsed);
+}
+
+static PyObject *
+_testinternalcapi_bench_critical_section2(PyObject *self, PyObject *args)
+{
+    PyObject *obj1, *obj2;
+    int iterations;
+    if (!PyArg_ParseTuple(args, "OOi", &obj1, &obj2, &iterations))
+        return NULL;
+    double elapsed = _PyCriticalSection_BenchCS2(obj1, obj2, iterations);
+    return PyFloat_FromDouble(elapsed);
+}
